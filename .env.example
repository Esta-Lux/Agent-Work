SUPABASE_URL=https://your-project.supabase.co
# Browser client (optional if SUPABASE_URL is set — next.config mirrors it)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-sb-secret-or-service-role-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-sb-publishable-or-anon-key

# Auth — comma-separated admin emails; dev bypass only for local (never in production)
BOOTRISE_ADMIN_EMAILS=you@company.com

# Local dev (no Supabase / no password) — copy into .env.local and restart `npm run dev`
# See docs/DEV.md for full details.
# Local dev: auth bypass is automatic in `npm run dev`. To test real login:
# BOOTRISE_DEV_AUTH_STRICT=1
# BOOTRISE_DEV_AUTH_BYPASS=0
# BOOTRISE_DEV_USER_ID=dev-user
# BOOTRISE_DEV_USER_EMAIL=dev@bootrise.local
# BOOTRISE_DEV_ORG_ID=org_default

# BootRise AI chat/fix (NVIDIA NIM) — required for full AI replies; chat works offline without it
# Get a key: https://build.nvidia.com/
NVIDIA_API_KEY=replace-with-nvidia-api-key
# Stronger default for code review + planning (override in .env if needed)
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# OpenAI ChatGPT 5.5 (optional second provider)
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5

# Optional — private GitHub repos + higher rate limits + automated push
GITHUB_TOKEN=

# Monorepo / large workspace tuning
BOOTRISE_PREVIEW_DEV=1
BOOTRISE_PREVIEW_INSTALL_MS=300000
BOOTRISE_SANDBOX_FULL=1
BOOTRISE_SANDBOX_INSTALL_MS=300000
BOOTRISE_SANDBOX_VERIFY_MS=120000
BOOTRISE_GITHUB_PUSH_MAX_FILES=500

# Regression guard (runs targeted npm/python verify before approve)
BOOTRISE_REGRESSION_INSTALL_MS=120000
BOOTRISE_REGRESSION_VERIFY_MS=90000
# BOOTRISE_SKIP_REGRESSION_EXEC=1
# Dev/test only — skips executing npm/py verify (checks still run statically)

# Visual smoke — requires: npm install -D playwright && npx playwright install chromium
# BOOTRISE_VISUAL_SMOKE=1
# BOOTRISE_VISUAL_SMOKE_URL=http://127.0.0.1:3000

# Code review depth (large repos like SnapRoad ~1100 files)
# auto = multi-pass when corpus >= 120 files + broad/HUD question
# BOOTRISE_REVIEW_MODE=auto
# BOOTRISE_REVIEW_SINGLE_MAX=64
# BOOTRISE_REVIEW_BATCH_SIZE=36
# BOOTRISE_REVIEW_MAX_BATCHES=8
# BOOTRISE_REVIEW_CHARS_PER_FILE=3500

# Multi-tenant org (must match bootrise_organizations.id in Supabase)
BOOTRISE_DEFAULT_ORG_ID=org_default
NEXT_PUBLIC_BOOTRISE_ORG_ID=org_default
# Default quota plan while auth/billing are still being wired: free, trial, internal, beta, pro, team, agency
BOOTRISE_DEFAULT_PLAN=internal

# Preview: auto | webcontainer | host
BOOTRISE_PREVIEW_MODE=auto

# Device farm streams — use {repositoryId} in URL
# BOOTRISE_ANDROID_STREAM_URL=https://stream.example.com/android/{repositoryId}
# BOOTRISE_IOS_STREAM_URL=https://stream.example.com/ios/{repositoryId}
# BOOTRISE_WEBRTC_SIGNAL_URL=wss://signal.example.com/{repositoryId}
